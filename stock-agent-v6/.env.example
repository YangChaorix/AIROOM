# DeepSeek（必填）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# LangSmith（必填；用于审查 LLM 调用和 ReAct 工具 span）
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_xxxxxxxx
LANGSMITH_PROJECT=stock-agent-v6-mvp

# AkShare 无需 API key；失败时工具层会返回 data_gap，管道继续

# 数据库（Phase 3）；默认 sqlite:///data/stock_agent.db
# 测试场景可覆盖为 sqlite:///:memory:
STOCK_AGENT_DB_URL=sqlite:///data/stock_agent.db

# 应用时区（IANA 名）；DB 入库/查询 cutoff 统一用这个时区的 naive datetime
# 默认 Asia/Shanghai；跨时区迁移时改这一个值即可
APP_TIMEZONE=Asia/Shanghai
