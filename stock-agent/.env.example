# ============================================================
# 选股Agent项目环境变量配置示例
# 复制此文件为 .env 并填写实际值
# 注意：.env 文件不应提交到版本控制系统
# ============================================================

# ---- DeepSeek API 配置（必填）----
# 从 https://platform.deepseek.com/ 获取 API Key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# DeepSeek API 基础 URL（使用 OpenAI 兼容接口）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 使用的模型名称
# 可选：deepseek-chat（性价比高）、deepseek-reasoner（推理增强）
DEEPSEEK_MODEL_NAME=deepseek-chat

# 模型温度（0.0-1.0，越低越稳定，推荐0.1）
DEEPSEEK_TEMPERATURE=0.1

# 最大输出 Token 数
DEEPSEEK_MAX_TOKENS=4096

# ---- Akshare 数据配置（可选，有默认值）----
# 历史K线数据获取天数（默认90天）
AKSHARE_KLINE_DAYS=90

# 新闻获取条数（默认20条）
AKSHARE_NEWS_COUNT=20

# 请求超时时间，单位秒（默认30秒）
AKSHARE_TIMEOUT=30

# ---- Agent 运行配置（可选，有默认值）----
# 每个子Agent最大迭代次数（默认5次）
AGENT_MAX_ITERATIONS=5

# 是否启用详细日志（true/false，默认false）
AGENT_VERBOSE=false

# 并行执行超时时间，单位秒（默认120秒）
AGENT_PARALLEL_TIMEOUT=120
