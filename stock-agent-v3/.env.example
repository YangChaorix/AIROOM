# ── LLM API Keys（按 provider 配置，key 名称需与 config/models.json 中 api_key_env 对应）──
DEEPSEEK_API_KEY=your_deepseek_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key
# 切换模型：编辑 config/models.json 中 agents.*.model 字段即可，格式为 provider/model-id
SERPER_API_KEY=your_serper_api_key

# ── Web 认证 ────────────────────────────────────────────────
WEB_USERNAME=admin
WEB_PASSWORD=admin123
# WEB_TOKEN_SECRET=your_custom_secret   # 可选，不设置则用内置默认值

# ── 日志 ────────────────────────────────────────────────────
# LOG_LEVEL=INFO                        # DEBUG / INFO / WARNING / ERROR
# LOG_FILE_ENABLED=true                 # false = 只输出到控制台，不写文件

# ── 数据库 ─────────────────────────────────────────────────
AGENT_DB_PATH=data/db/stock_agent.db

# ── AkShare 行情数据 ────────────────────────────────────────
# AKSHARE_KLINE_DAYS=90                 # K线回溯天数
# AKSHARE_NEWS_COUNT=30                 # 个股新闻条数
# AKSHARE_TIMEOUT=30                    # 请求超时（秒）

# ── Agent 运行参数 ──────────────────────────────────────────
# AGENT_MAX_ITERATIONS=10               # LangGraph 最大迭代步数
# AGENT_VERBOSE=false                   # true = 打印 Agent 中间步骤

# ── 新闻采集：时效过滤 ───────────────────────────────────────
# 发布时间超过 N 天的新闻跳过不入库；0 = 不限制
NEWS_MAX_AGE_DAYS=3

# ── 新闻采集：各优先级采集间隔（分钟） ───────────────────────
COLLECT_INTERVAL_HIGH=30        # 财联社 / 东方财富 / 同花顺
COLLECT_INTERVAL_MEDIUM=60      # 新浪财经 / 财联社电报
COLLECT_INTERVAL_LOW=120        # 国家发改委 / 财新

# ── 新闻采集：各优先级活跃时段（24h制，支持多段 "6-9,15-18"） ─
# 默认规则：
#   早盘前（6-9）  → HIGH + MEDIUM + LOW 各采一轮
#   盘中 （9-15）  → HIGH + MEDIUM，LOW 不采
#   盘后 （15-18） → MEDIUM + LOW，HIGH 不采
#   夜间 （18-6）  → 全部不采
COLLECT_HIGH_HOURS=6-15
COLLECT_MEDIUM_HOURS=6-18
COLLECT_LOW_HOURS=6-9,15-18

# ── 新闻采集：APScheduler 定时触发配置 ───────────────────────
# 调度器触发时段（APScheduler hour 表达式，覆盖所有优先级的最大窗口即可）
COLLECT_SCHEDULE_HOURS=6-17
# 调度器触发间隔（分钟，建议与 COLLECT_INTERVAL_HIGH 保持一致）
COLLECT_SCHEDULE_INTERVAL=30

# ── Critic Agent（批评报告 → 精筛 Prompt 自动优化） ──────────
# true  = 每次批评后立即激活新精筛 Prompt（适合信任 LLM 判断的场景）
# false = 保存为"待审核"状态，需在 Web UI 手动点击激活（默认，更安全）
# 也可在 Web UI「系统配置」页面动态开关，无需重启
CRITIC_SCREENER_AUTO_ACTIVATE=false

# ── Review Agent（市场复盘 → 触发检测 Prompt 自动优化） ──────
# true  = 每次复盘后立即激活新触发 Prompt
# false = 保存为"待审核"状态，需在 Web UI 手动点击激活（默认，更安全）
# 也可在 Web UI「系统配置」页面动态开关，无需重启
REVIEW_TRIGGER_AUTO_ACTIVATE=false
