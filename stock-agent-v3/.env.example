DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-chat
SERPER_API_KEY=your_serper_api_key
AGENT_DATA_DIR=data/daily_push

# ── 数据库 ─────────────────────────────────────────────────
# SQLite 文件路径（相对于项目根目录）
AGENT_DB_PATH=data/stock_agent.db

# ── 新闻采集：各优先级采集间隔（分钟） ───────────────────────
COLLECT_INTERVAL_HIGH=30        # 财联社 / 东方财富 / 同花顺
COLLECT_INTERVAL_MEDIUM=60      # 新浪财经 / 财联社电报
COLLECT_INTERVAL_LOW=120        # 国家发改委 / 财新

# ── 新闻采集：各优先级活跃时段（24h制，支持多段 "6-9,15-18"） ─
# 默认规则：
#   早盘前（6-9）  → HIGH + MEDIUM + LOW 各采一轮
#   盘中 （9-15）  → HIGH + MEDIUM，LOW 不采
#   盘后 （15-18） → MEDIUM + LOW，HIGH 不采
#   夜间 （18-6）  → 全部不采
COLLECT_HIGH_HOURS=6-15
COLLECT_MEDIUM_HOURS=6-18
COLLECT_LOW_HOURS=6-9,15-18

# ── 新闻采集：APScheduler 定时触发配置 ───────────────────────
# 调度器触发时段（APScheduler hour 表达式，覆盖所有优先级的最大窗口即可）
COLLECT_SCHEDULE_HOURS=6-17
# 调度器触发间隔（分钟，建议与 COLLECT_INTERVAL_HIGH 保持一致）
COLLECT_SCHEDULE_INTERVAL=30
